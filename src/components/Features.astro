---
const features = [
  {
    icon: "rocket",
    title: "Ship in Minutes, Not Months",
    description:
      "Push to deploy with zero-config CI/CD. Preview environments spin up on every pull request so reviewers see exactly what customers will see.",
  },
  {
    icon: "shield",
    title: "Enterprise-Grade Security",
    description:
      "SOC 2 Type II certified with built-in audit trails, role-based access control, and end-to-end encryption. Your security team will approve it on the first review.",
  },
  {
    icon: "chart",
    title: "Observability Built In",
    description:
      "Distributed tracing, real-time error tracking, and custom dashboards ship out of the box. No third-party integrations to configure or maintain.",
  },
  {
    icon: "puzzle",
    title: "Integrates With Everything",
    description:
      "First-class plugins for GitHub, GitLab, Slack, Jira, Datadog, PagerDuty, and fifty more tools your team already uses. Open APIs for everything else.",
  },
  {
    icon: "users",
    title: "Built for Teams",
    description:
      "Workspaces, fine-grained permissions, and shared environments let your entire organization collaborate without stepping on each other's toes.",
  },
  {
    icon: "code",
    title: "Developer Experience First",
    description:
      "A CLI that feels native, SDKs in every major language, and documentation written by engineers who actually use the product. No jargon, no hand-waving.",
  },
];

const iconPaths: Record<string, string> = {
  rocket: "M9.315 7.584C12.195 3.883 16.695 1.5 21.75 1.5a.75.75 0 0 1 .75.75c0 5.056-2.383 9.555-6.084 12.436A6.75 6.75 0 0 1 9.75 22.5a.75.75 0 0 1-.75-.75v-4.131A15.838 15.838 0 0 1 1.382 6.916a.75.75 0 0 1 .67-1.154 15.838 15.838 0 0 0 7.263 1.822Z",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  chart: "M3 3v18h18M9 17V9m4 8V5m4 12v-4",
  puzzle: "M12 2a3 3 0 0 0-3 3c0 .6.2 1.2.5 1.6L7.1 9H5a3 3 0 0 0 0 6h2.1l2.4 2.4c-.3.4-.5 1-.5 1.6a3 3 0 0 0 6 0c0-.6-.2-1.2-.5-1.6l2.4-2.4H19a3 3 0 0 0 0-6h-2.1l-2.4-2.4c.3-.4.5-1 .5-1.6a3 3 0 0 0-3-3z",
  users: "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2M9 7a4 4 0 1 0 0 8 4 4 0 0 0 0-8zm13 14v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75",
  code: "m16 18 6-6-6-6M8 6l-6 6 6 6",
};
---
<section id="features" class="py-20 px-4 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Everything your team needs to ship with confidence</h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">
        One platform replaces your CI runner, feature-flag service, and half your observability stack.
        Less moving parts. Fewer 2 AM pages.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((f) => (
        <div class="p-6 rounded-xl border border-gray-100 hover:border-blue-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 rounded-lg bg-blue-50 flex items-center justify-center mb-4">
            <svg class="w-5 h-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d={iconPaths[f.icon]} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold mb-2">{f.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
