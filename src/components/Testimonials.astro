---
const quotes = [
  { text: "Incredible product. Saved us months.", author: "Jane D., CTO" },
  { text: "Best tool we have adopted this year.", author: "Alex R., VP Eng" },
  { text: "Simple, powerful, and reliable.", author: "Sam K., Founder" },
];
---
<section class="py-16 px-4 bg-gray-50">
  <h2 class="text-3xl font-bold text-center mb-10">What people say</h2>
  <div class="max-w-5xl mx-auto grid md:grid-cols-3 gap-6">
    {quotes.map((q) => (
      <blockquote class="bg-white p-6 rounded-lg shadow">
        <p class="italic text-gray-700">&ldquo;{q.text}&rdquo;</p>
        <footer class="mt-3 text-sm font-semibold text-gray-500">{q.author}</footer>
      </blockquote>
    ))}
  </div>
</section>
