---
import { getBlogPosts, type BlogPost } from "../lib/supabase";

// Try Supabase first, fall back to hardcoded data
let posts: BlogPost[] = await getBlogPosts();

if (posts.length === 0) {
  posts = [
    {
      id: "1",
      title: "Why We Built an Open Platform",
      slug: "why-we-built-an-open-platform",
      excerpt: "Closed ecosystems create lock-in. We chose a different path: open APIs, portable data, and no vendor lock-in.",
      content: "",
      author_name: "Alex Rivera",
      published_at: new Date(Date.now() - 5 * 86400000).toISOString(),
      created_at: new Date().toISOString(),
    },
    {
      id: "2",
      title: "Achieving SOC 2 Without Slowing Down",
      slug: "soc-2-without-slowing-down",
      excerpt: "Compliance does not have to kill velocity. We share the engineering patterns that let us ship daily.",
      content: "",
      author_name: "Jordan Lee",
      published_at: new Date(Date.now() - 12 * 86400000).toISOString(),
      created_at: new Date().toISOString(),
    },
    {
      id: "3",
      title: "From Monolith to Microservices: A Practical Guide",
      slug: "monolith-to-microservices-guide",
      excerpt: "The internet is full of microservices advice. Most of it is wrong for teams under fifty engineers.",
      content: "",
      author_name: "Sam Nakamura",
      published_at: new Date(Date.now() - 20 * 86400000).toISOString(),
      created_at: new Date().toISOString(),
    },
  ];
}

function formatDate(dateStr: string | null): string {
  if (!dateStr) return "";
  return new Date(dateStr).toLocaleDateString("en-US", {
    month: "long",
    day: "numeric",
    year: "numeric",
  });
}
---
<section id="blog" class="py-20 px-4 bg-gray-50">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">From the blog</h2>
      <p class="text-lg text-gray-500 max-w-2xl mx-auto">
        Engineering insights, product updates, and the occasional opinion.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-8">
      {posts.slice(0, 3).map((post) => (
        <article class="bg-white rounded-xl border border-gray-100 overflow-hidden hover:shadow-md transition-shadow">
          <div class="p-6">
            <time class="text-xs font-medium text-gray-400 uppercase tracking-wide" datetime={post.published_at ?? undefined}>
              {formatDate(post.published_at)}
            </time>
            <h3 class="text-lg font-semibold mt-2 mb-3 leading-snug">
              <a href={`/blog/${post.slug}`} class="hover:text-blue-600 transition-colors">
                {post.title}
              </a>
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">{post.excerpt}</p>
            <p class="text-xs text-gray-400">By {post.author_name}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
