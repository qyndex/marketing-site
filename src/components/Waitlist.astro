---
---
<section id="waitlist" class="py-20 px-4 bg-gradient-to-br from-blue-600 to-purple-700 text-white">
  <div class="max-w-2xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-4">Get early access</h2>
    <p class="text-lg opacity-90 mb-8">
      Join the waitlist and be the first to know when we launch. No spam, just one email when it is your turn.
    </p>
    <form
      id="waitlist-form"
      class="flex flex-col sm:flex-row gap-3 max-w-lg mx-auto"
      action="/api/waitlist"
      method="POST"
    >
      <input
        type="text"
        name="name"
        placeholder="Your name"
        class="flex-1 px-4 py-3 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-300"
        aria-label="Your name"
      />
      <input
        type="email"
        name="email"
        required
        placeholder="you@company.com"
        class="flex-1 px-4 py-3 rounded-lg text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-300"
        aria-label="Email address"
      />
      <button
        type="submit"
        class="bg-white text-blue-700 font-semibold px-6 py-3 rounded-lg hover:bg-blue-50 transition-colors whitespace-nowrap"
      >
        Join Waitlist
      </button>
    </form>
    <p id="waitlist-message" class="mt-4 text-sm opacity-0 transition-opacity duration-300" aria-live="polite"></p>
  </div>
</section>

<script>
  const form = document.getElementById("waitlist-form") as HTMLFormElement | null;
  const message = document.getElementById("waitlist-message") as HTMLElement | null;

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch("/api/waitlist", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: data.get("name"),
          email: data.get("email"),
        }),
      });

      if (message) {
        if (res.ok) {
          message.textContent = "You are on the list! We will be in touch soon.";
          message.classList.remove("opacity-0", "text-red-200");
          message.classList.add("opacity-100");
          form.reset();
        } else {
          const err = await res.json().catch(() => ({ error: "Something went wrong." }));
          message.textContent = err.error ?? "Something went wrong. Please try again.";
          message.classList.remove("opacity-0");
          message.classList.add("opacity-100", "text-red-200");
        }
      }
    } catch {
      if (message) {
        message.textContent = "Network error. Please check your connection and try again.";
        message.classList.remove("opacity-0");
        message.classList.add("opacity-100", "text-red-200");
      }
    }
  });
</script>
